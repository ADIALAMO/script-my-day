{
  "version": 2,
  "framework": "nextjs",
  "cleanUrls": true,
  "functions": {
    "pages/api/generate-script.js": { "maxDuration": 60 },
    "pages/api/generate-storyboard.js": { "maxDuration": 60 },
    "pages/api/generate-poster.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}