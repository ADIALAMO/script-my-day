# ── AI Providers ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=                  # Primary paid key — stages 2 & 4 (Gemma, DeepSeek)
OPENROUTER_FREE_KEY=                 # Free-tier backup key — stage 5 last resort

GOOGLE_GEMINI_API_KEY=               # Stage 1 (Gemini flash models race)
GEMINI_API_KEY=                      # Alias used by some routes — keep in sync with above

COHERE_API_KEY=                      # Stage 3 (Cohere Command R+)
HF_TOKEN=                            # Hugging Face — image generation pipeline

# ── Cloudflare R2 (image / asset storage) ─────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                       # Public CDN base URL for stored images

# ── Site URL (absolute base for OG images + invite links) ─────────────────────
NEXT_PUBLIC_SITE_URL=                 # Canonical absolute base, e.g. https://lifescript.app
                                     # MUST be a LIVE domain (crawlers fetch og:image from it).
                                     # Unset → falls back to the Vercel deployment URL so OG
                                     # previews never 404. Set to the custom domain once it's
                                     # connected, then redeploy. NEXT_PUBLIC_ = available on
                                     # server+client (no hydration mismatch) + inlined at build.

# ── Upstash Redis (quota tracking) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cost safety ───────────────────────────────────────────────────────────────
DAILY_IDENTITY_BUDGET=               # Optional USD ceiling on TOTAL "Star Yourself" spend
                                     # per UTC day. Once reached, identity degrades to the
                                     # faceless cascade (app stays up) until midnight UTC.
                                     # Unset = no cap. Worst-case cost/call assumed = $0.06.
REFERRAL_REWARD_CAP=                 # Optional max identity credits ONE referrer can earn
                                     # via the invite loop (default 10 → ~$0.60 cap/referrer).

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Use pk_test_ / sk_test_ for local dev; pk_live_ / sk_live_ for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Billing gate (pre-launch waitlist) ────────────────────────────────────────
# Leave false/unset while Stripe is in Test Mode: the public sees a Pro WAITLIST
# instead of the checkout, so nobody can self-unlock unlimited generation with
# the 4242 test card and burn the AI/infra budget. Flip to "true" the day Stripe
# goes Live — no code change needed.
NEXT_PUBLIC_BILLING_ENABLED=false
# Comma-separated emails that get Pro on sign-in WITHOUT Stripe (invited
# influencers / key testers). Access is bound to identity, so it can't leak like
# a shareable link would. e.g. you@example.com,creator@example.com
PRO_ALLOWLIST=

# ── Authentication (NextAuth) ─────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                     # Random 32-char secret: `openssl rand -base64 32`
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (magic link auth) ───────────────────────────────────────────────────
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=               # Gmail app password (not your account password)
EMAIL_FROM=                          # e.g. "LifeScript Studio <you@gmail.com>"

# ── Telegram (admin notifications) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SECRET=                        # Secret for admin API bypass
ADMIN_EMAILS=                        # Comma-separated admin email addresses
